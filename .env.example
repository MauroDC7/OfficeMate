APP_NAME=TimeTraq
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Shared hosting (bachelor): use pusher — no WebSocket server nodig.
# Lokaal met Reverb: zet op reverb en start `php artisan reverb:start`.
BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
# Op shared hosting zonder queue-worker: sync. Met cron/queue-worker: database.
QUEUE_CONNECTION=sync

# Pusher Channels (https://dashboard.pusher.com) — productie / webhosting
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu

VITE_BROADCAST_DRIVER="${BROADCAST_CONNECTION}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Laravel Reverb (optioneel, alleen lokaal)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Lokaal: smtp + Mailpit (poort 1025). Productie (timetraq.be): postmark.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@timetraq.be"
MAIL_FROM_NAME="${APP_NAME}"

# Postmark (https://account.postmarkapp.com) — alleen nodig als MAIL_MAILER=postmark
POSTMARK_TOKEN=
# Message stream in Postmark (bijv. "bachelor" of standaard "outbound")
POSTMARK_MESSAGE_STREAM_ID=outbound

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (login / registratie via Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# OpenAI (ChatGPT) — gebruikt voor AI-voorstellen op basis van de desktop-tracker.
# gpt-4o-mini is een goedkoop model dat goed werkt voor korte Nederlandstalige samenvattingen.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Tijdzone voor timesheet-voorstellen (daggrenzen); standaard België.
TIMESHEETS_TIMEZONE=Europe/Brussels

# Slack (optioneel — Incoming Webhook werkt op Free workspaces)
# Webhook-URL: api.slack.com/apps → jouw app → Incoming Webhooks → Add New Webhook
SLACK_INCOMING_WEBHOOK_URL=
# App Credentials (Basic Information) — voor later OAuth / Slack → TimeTraq
SLACK_APP_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Optioneel: pad naar een lokale ActivityWatch JSON-export (fallback bron voor
# AI-voorstellen wanneer de TimeTraq Tracker nog geen data verstuurd heeft).
# Standaard: storage/app/activitywatch
ACTIVITYWATCH_EXPORT_PATH=
