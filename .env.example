APP_NAME=TimeTraq
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=nl
APP_FALLBACK_LOCALE=en

# Web Push (genereer keys: php artisan webpush:vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="${APP_URL}"
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Pusher Channels (shared hosting + lokaal). Vereist pusher/pusher-php-server + npm run build na invullen.
BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
# Combell HTTP-cron: geheim voor https://timetraq.be/jobs/task.php?token=...
# Genereer: php artisan str:random 64
CRON_SECRET=

# Combell (alternatief CLI-cron): elke minuut schedule:run — anders geen weekly-debrief-mails.
#   * * * * * cd /pad/naar/site && php artisan schedule:run >> /dev/null 2>&1
# HTTP-cron in Combell-panel (elke minuut, liefst alleen vrijdag):
#   https://timetraq.be/jobs/task.php?token=JOUW_CRON_SECRET
# Op shared hosting zonder queue-worker: sync (aanbevolen). Met extra cron: database.
QUEUE_CONNECTION=sync

# Pusher Channels (https://dashboard.pusher.com) — productie / webhosting
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu

VITE_BROADCAST_DRIVER="${BROADCAST_CONNECTION}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Lokaal: smtp + Mailpit (poort 1025). Productie (timetraq.be): postmark.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@timetraq.be"
MAIL_FROM_NAME="${APP_NAME}"

# Postmark (https://account.postmarkapp.com) — alleen nodig als MAIL_MAILER=postmark
POSTMARK_TOKEN=
# Message stream in Postmark (bijv. "bachelor" of standaard "outbound")
POSTMARK_MESSAGE_STREAM_ID=outbound

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (login / registratie via Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# OpenAI (ChatGPT) — timesheet-voorstellen, weekly debrief en Timy (chat-assistent).
# gpt-4o-mini is een goedkoop model dat goed werkt voor korte Nederlandstalige samenvattingen.
# Zonder sleutel werkt Timy in eenvoudige modus op basis van je eigen TimeTraq-data.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Tijdzone voor timesheet-voorstellen (daggrenzen); standaard België.
TIMESHEETS_TIMEZONE=Europe/Brussels

# Weekly debrief e-mailherinnering (0=zondag … 5=vrijdag; tijd in TIMESHEETS_TIMEZONE).
WEEKLY_DEBRIEF_REMINDER_WEEKDAY=5
WEEKLY_DEBRIEF_REMINDER_TIME=15:00

# Download-URL voor de TimeTraq Tracker (Instellingen → Installatie). Leeg = GitHub-release v1.0.0.
TIMETRAQ_TRACKER_DOWNLOAD_URL=https://github.com/MauroDC7/tracker/releases/tag/v1.0.0

# Slack (optioneel — Incoming Webhook werkt op Free workspaces)
# Webhook-URL: api.slack.com/apps → jouw app → Incoming Webhooks → Add New Webhook
SLACK_INCOMING_WEBHOOK_URL=
# App Credentials (Basic Information) — voor later OAuth / Slack → TimeTraq
SLACK_APP_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Optioneel: pad naar een lokale ActivityWatch JSON-export (fallback bron voor
# AI-voorstellen wanneer de TimeTraq Tracker nog geen data verstuurd heeft).
# Standaard: storage/app/activitywatch
ACTIVITYWATCH_EXPORT_PATH=
